{
  "name": "@toko/cli",
  "version": "0.1.0",
  "description": "CLI Tokō — accès en lecture seule aux données de suivi pour les agents disposant d'un terminal",
  "private": true,
  "type": "module",
  "bin": {
    "toko": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
