{
  "expo": {
    "name": "Tokō",
    "slug": "toko",
    "scheme": "toko",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "platforms": ["android"],
    "android": {
      "package": "app.toko.mobile",
      "versionCode": 1,
      "permissions": [
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#ffffff"
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "https://toko.app",
      "webUrl": "https://toko.app",
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
