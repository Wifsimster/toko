{
  "name": "@focusflow/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:seed": "tsx --env-file-if-exists=../../.env src/seed.ts"
  },
  "dependencies": {
    "@focusflow/db": "workspace:*",
    "@focusflow/validators": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "better-auth": "^1.5.6",
    "drizzle-orm": "0.45.1",
    "hono": "^4.6.0",
    "stripe": "^20.4.1",
    "tsx": "^4.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
